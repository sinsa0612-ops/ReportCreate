# API Keys - 이 파일을 .env 로 복사한 뒤 실제 키를 입력하세요
# (.env 는 .gitignore 에 등록되어 커밋되지 않습니다)

# --- 검색 레이어 (지금 필요) ---
TAVILY_API_KEY=your_tavily_api_key   # https://app.tavily.com  · 무료 1,000회/월
EXA_API_KEY=your_exa_api_key         # https://exa.ai          · 무료 1,000회/월

# --- 공식 데이터 API (선택) ---
EIA_API_KEY=your_eia_api_key         # https://www.eia.gov/opendata/ · 무료
# arXiv, Semantic Scholar 는 키 불필요

# --- 완전 자율(무인) 모드 전환 시에만 추가 ---
# 현재는 보고서 생성을 Claude Code 세션에서 직접 처리하므로 불필요.
# 스크립트 단독 실행(cron 등)으로 전환할 때 아래 주석을 해제하세요.
# ANTHROPIC_API_KEY=your_anthropic_api_key

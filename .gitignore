# --- 비밀 정보 (절대 업로드 금지) ---
.env

# --- 파이썬 가상환경 / 캐시 ---
.venv/
__pycache__/
*.pyc

# --- 생성된 결과물 (용량 큼, 재생성 가능) ---
output/

# --- 저작권 있는 외부 자료 / 대용량 파일 ---
library/
*.msi

# --- 도구/프레임워크 파일 (프로젝트 코드 아님) ---
.claude/
.agent/
.agents/
_bmad/
_bmad-output/

# --- 압축파일 (실수로 전체 프로젝트/키 업로드 방지) ---
*.zip
